{
  "info": {
    "name": "SIGE-PLUS API Collection",
    "description": "Complete API testing collection for SIGE-PLUS project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Login Local",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('auth_token', jsonData.token);",
                  "    pm.environment.set('user_matricula', jsonData.user.matricula);",
                  "    pm.test('Status code is 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                  "    pm.test('Response has token', function () { pm.expect(jsonData.token).to.exist; });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"matricula\": \"2021004562\",\\n  \"password\": \"123456\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "SIGE Integration",
      "item": [
        {
          "name": "Extract Data from SIGE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 401', function () {",
                  "    pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test('Response has success flag', function () {",
                  "        pm.expect(jsonData.success).to.be.true;",
                  "    });",
                  "    pm.test('Response has data object', function () {",
                  "        pm.expect(jsonData.data).to.exist;",
                  "    });",
                  "    pm.environment.set('extracted_data', JSON.stringify(jsonData.data));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"phpsessid\": \"{{sige_session_id}}\",\\n  \"matricula\": \"{{user_matricula}}\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sige/extract-data",
              "host": ["{{base_url}}"],
              "path": ["api", "sige", "extract-data"]
            }
          }
        },
        {
          "name": "Save Data to Database",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test('Response indicates success', function () {",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "pm.test('Response contains student info', function () {",
                  "    pm.expect(jsonData.estudiante).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"data\": {{extracted_data}},\\n  \"matricula\": \"{{user_matricula}}\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sige/save-to-db",
              "host": ["{{base_url}}"],
              "path": ["api", "sige", "save-to-db"]
            }
          }
        },
        {
          "name": "Get Academic Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test('Response has academico object', function () {",
                  "    pm.expect(jsonData.academico).to.exist;",
                  "    pm.expect(jsonData.academico.promedioGeneral).to.be.a('number');",
                  "});",
                  "pm.test('Response has pagoMensual object', function () {",
                  "    pm.expect(jsonData.pagoMensual).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sige/academic-data?matricula={{user_matricula}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sige", "academic-data"],
              "query": [
                {
                  "key": "matricula",
                  "value": "{{user_matricula}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Proxy Image",
          "event": [
            {
              "listen": "test",
              "script": [
                "pm.test('Status is 200', function () {",
                "    pm.expect(pm.response.code).to.equal(200);",
                "});",
                "pm.test('Response is image or SVG', function () {",
                "    var contentType = pm.response.headers.get('content-type');",
                "    pm.expect(contentType).to.include.oneOf(['image/', 'svg']);",
                "});"
              ]
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sige/proxy-image?matricula={{user_matricula}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sige", "proxy-image"],
              "query": [
                {
                  "key": "matricula",
                  "value": "{{user_matricula}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pagos Mensuales",
      "item": [
        {
          "name": "Registrar Pago",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 500', function () {",
                  "    pm.expect([201, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test('Response indicates success', function () {",
                  "        pm.expect(jsonData.success).to.be.true;",
                  "    });",
                  "    pm.test('Response has pago object', function () {",
                  "        pm.expect(jsonData.pago).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \"matricula\": \"{{user_matricula}}\",\\n  \"mes\": \"Enero 2026\",\\n  \"montoBase\": 250,\\n  \"recargo\": 0,\\n  \"totalPagar\": 250,\\n  \"concepto\": \"Inscripción\",\\n  \"folio\": \"RCB-{{$timestamp}}\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/pagos-mensuales/registrar-pago",
              "host": ["{{base_url}}"],
              "path": ["api", "pagos-mensuales", "registrar-pago"]
            }
          }
        },
        {
          "name": "Obtener Pagos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test('Response has success flag', function () {",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "pm.test('Response has pagos array', function () {",
                  "    pm.expect(jsonData.pagos).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/pagos-mensuales/obtener-pagos?matricula={{user_matricula}}&meses=6",
              "host": ["{{base_url}}"],
              "path": ["api", "pagos-mensuales", "obtener-pagos"],
              "query": [
                {
                  "key": "matricula",
                  "value": "{{user_matricula}}"
                },
                {
                  "key": "meses",
                  "value": "6"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
