---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="light" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Public Sans", sans-serif;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
    </style>
  </head>
  <body
    class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex flex-col"
  >
    <!-- Institutional Header -->
    <header class="w-full bg-white">
      <div class="hidden lg:block bg-primary py-2 px-4 lg:px-6">
        <div
          class="max-w-7xl mx-auto flex flex-wrap justify-end gap-3 lg:gap-6 text-[10px] font-bold text-white uppercase tracking-wider"
        >
          <a
            href="/"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Inicio</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Oferta Educativa</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Comunicación</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Transparencia</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Normatividad</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Nosotros</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Radio UTSH</a
          >
          <a
            href="#"
            class="hover:text-accent transition-colors whitespace-nowrap"
            >Contacto</a
          >
        </div>
      </div>
      <div
        class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6 py-3 sm:py-4 flex items-center justify-between gap-2 sm:gap-4"
      >
        <a
          href="/"
          class="flex items-center gap-2 sm:gap-3 hover:opacity-80 transition-opacity min-w-0 flex-1"
        >
          <div class="bg-zinc-100 p-1.5 sm:p-2 rounded flex-shrink-0">
            <span
              class="material-symbols-outlined text-zinc-600 text-xl sm:text-2xl"
              >school</span
            >
          </div>
          <div class="min-w-0">
            <h1
              class="text-sm sm:text-base lg:text-lg font-black text-slate-800 leading-none tracking-tight truncate"
            >
              UNIVERSIDAD TECNOLÓGICA
            </h1>
            <p
              class="text-[10px] sm:text-xs text-slate-500 font-medium truncate"
            >
              de la Sierra Hidalguense
            </p>
          </div>
        </a>

        <!-- Login/User Menu -->
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <!-- Login Button (shown when not logged in) -->
          <a
            id="login-btn"
            href="/login?redirect=/pagos-mensuales/paso-2"
            class="hidden bg-primary hover:bg-primary/90 text-white px-3 sm:px-4 lg:px-6 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-xs font-bold uppercase tracking-wide sm:tracking-widest transition-all whitespace-nowrap"
          >
            <span class="hidden sm:inline">Iniciar Sesión</span>
            <span class="sm:hidden">Login</span>
          </a>

          <!-- User Info (shown when logged in) -->
          <div id="user-menu" class="hidden items-center gap-2 sm:gap-3">
            <div class="text-right hidden sm:block">
              <p
                id="user-name-display"
                class="text-xs sm:text-sm font-bold text-slate-800 leading-tight"
              >
              </p>
              <p class="text-[10px] text-slate-500">Estudiante</p>
            </div>
            <button
              id="logout-btn-header"
              class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-xs font-bold transition-all whitespace-nowrap"
            >
              <span class="hidden sm:inline">Cerrar Sesión</span>
              <span class="sm:hidden">Salir</span>
            </button>
          </div>
        </div>
      </div>
      <div class="h-[2px] w-full bg-accent"></div>
    </header>

    <!-- Main Content -->
    <slot />

    <!-- Institutional Footer -->
    <footer class="w-full bg-maroon text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <div
          class="grid grid-cols-1 md:grid-cols-3 gap-8 sm:gap-12 items-start text-center md:text-left"
        >
          <div class="flex flex-col items-center md:items-start gap-4">
            <p
              class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest leading-relaxed opacity-80"
            >
              Estado Libre y Soberano de Hidalgo<br />Universidad Tecnológica de
              la Sierra Hidalguense
            </p>
          </div>
          <div class="flex justify-center gap-8 sm:gap-16">
            <div class="text-center">
              <h6 class="text-2xl sm:text-3xl font-black">911</h6>
              <p
                class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest opacity-70 mt-1"
              >
                Emergencia
              </p>
            </div>
            <div class="text-center">
              <h6 class="text-2xl sm:text-3xl font-black">070</h6>
              <p
                class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest opacity-70 mt-1"
              >
                Atención Ciudadana
              </p>
            </div>
          </div>
          <div class="space-y-4 text-xs">
            <div class="text-center md:text-right">
              <p
                class="font-bold mb-2 uppercase tracking-widest text-[10px] sm:text-xs"
              >
                Aviso de Privacidad
              </p>
              <p
                class="font-bold uppercase tracking-widest text-[10px] sm:text-xs"
              >
                Contacto
              </p>
            </div>
            <div
              class="text-center md:text-right opacity-80 leading-relaxed text-[10px] sm:text-xs"
            >
              <p>Carretera México Tampico k.m. 100</p>
              <p>Tramo Pachuca - Huejutla, C.P. 43200</p>
              <p>Zacualtipán de Ángeles, Hidalgo, México</p>
              <p class="font-bold mt-2">Tel: (774) 74 2 04 70</p>
            </div>
          </div>
        </div>
        <div
          class="mt-8 sm:mt-12 pt-4 sm:pt-6 border-t border-white/10 text-center"
        >
          <p
            class="text-[8px] sm:text-[9px] font-bold uppercase tracking-[0.2em] opacity-50"
          >
            Derechos Reservados 2026 © Universidad Tecnológica de la Sierra
            Hidalguense.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Check if user is logged in and update header
      const userStr = sessionStorage.getItem("user");
      const loginBtn = document.getElementById("login-btn");
      const userMenu = document.getElementById("user-menu");
      const userNameDisplay = document.getElementById("user-name-display");
      const logoutBtnHeader = document.getElementById("logout-btn-header");

      if (userStr && loginBtn && userMenu && userNameDisplay) {
        const user = JSON.parse(userStr);

        // Hide login button, show user menu
        loginBtn.classList.add("hidden");
        userMenu.classList.remove("hidden");
        userMenu.classList.add("flex");

        // Set user name
        const fullName = `${user.nombre} ${user.apellido_paterno}`.trim();
        userNameDisplay.textContent = fullName;

        // Handle logout
        if (logoutBtnHeader) {
          logoutBtnHeader.addEventListener("click", () => {
            sessionStorage.clear();
            window.location.href = "/pagos-mensuales/paso-1";
          });
        }
      } else if (loginBtn) {
        // Show login button when not logged in
        loginBtn.classList.remove("hidden");
      }
    </script>
  </body>
</html>
