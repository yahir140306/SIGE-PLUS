  /**
   * Guarda un pago en la base de datos
   */
  async function savePaymentToDB(
    payment: PaymentRow,
    receipt: ReceiptData,
  ): Promise<boolean> {
    try {
      console.log(`💾 Guardando pago ${payment.id} en BD...`);

      const response = await fetch(`/api/pagos-mensuales/registrar-pago`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          matricula: user.matricula,
          mes: payment.mes,
          montoBase: payment.montoOriginal,
          recargo: payment.recargo,
          totalPagar: payment.totalPagar,
          concepto: payment.concepto,
          folio: receipt.folio,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        console.error("❌ Error guardando pago:", errorData);

        // Si es error de tabla no encontrada, mostrar alerta informativa
        if (errorData.code === "TABLE_NOT_FOUND") {
          console.warn(
            "⚠️ Tabla de pagos no configurada. Contacta al administrador.",
          );
          // No interrumpir el flujo, permitir que el recibo se termine de mostrar
          return false;
        }

        throw new Error(errorData.error || "Error al guardar el pago en la BD");
      }

      const result = await response.json();
      console.log("✅ Pago guardado en BD:", result);
      return true;
    } catch (error) {
      console.error("❌ Error en savePaymentToDB:", error);
      // No lanzar error para no interrumpir el flujo del recibo
      return false;
    }
  }

  /**
   * Carga los pagos guardados del estudiante desde la BD
   */
  async function loadPaymentsFromDB(matricula: string): Promise<void> {
    try {
      console.log(`📂 Cargando pagos guardados para ${matricula}...`);

      const response = await fetch(
        `/api/pagos-mensuales/obtener-pagos?matricula=${matricula}&meses=12`,
      );

      if (!response.ok) {
        throw new Error("Error al cargar pagos guardados");
      }

      const result = await response.json();

      if (!result.success || !result.pagos || result.pagos.length === 0) {
        console.log("ℹ️ No hay pagos guardados en BD");
        return;
      }

      console.log(`✅ Se encontraron ${result.pagos.length} pagos guardados`);

      // Cargar los pagos guardados en paymentsState
      for (const savedPayment of result.pagos) {
        // Encontrar el pago correspondiente en paymentsState
        const paymentInState = paymentsState.find(
          (p) =>
            p.mes === savedPayment.mes ||
            p.mes ===
              `${new Date(savedPayment.fecha_pago).toLocaleString("es-ES", { month: "long", year: "numeric" })}`.toLowerCase(),
        );

        if (paymentInState) {
          // Actualizar el estado del pago
          paymentInState.estado = "pagado";
          paymentInState.fechaPagoISO = savedPayment.fecha_pago;

          // Recrear el recibo desde los datos guardados
          const reconstructedReceipt: ReceiptData = {
            folio: savedPayment.folio_recibo,
            matricula: user.matricula,
            alumno:
              `${user.nombre} ${user.apellido_paterno} ${user.apellido_materno || ""}`.trim(),
            concepto: savedPayment.concepto,
            fechaEmision: savedPayment.fecha_pago,
            montoBase: savedPayment.monto_base || paymentInState.montoOriginal,
            recargo: savedPayment.recargo_aplicado || paymentInState.recargo,
            total: savedPayment.total_pagado || paymentInState.totalPagar,
            paymentId: paymentInState.id,
          };

          receiptsStore.set(paymentInState.id, reconstructedReceipt);
          console.log(
            `✅ Recibo ${savedPayment.folio_recibo} cargado en memoria`,
          );
        }
      }

      renderPaymentsData();
    } catch (error) {
      console.error(
        "⚠️ Error cargando pagos guardados (continuando sin BD):",
        error,
      );
      // No interrumpir el flujo si hay error en cargar pagos guardados
    }
  }

  function buildReceipt(payment: PaymentRow): ReceiptData {
    const fullName =
      `${user.nombre} ${user.apellido_paterno} ${user.apellido_materno || ""}`.trim();

    return {
      folio: `RCB-${Date.now().toString().slice(-8)}`,
      matricula: user.matricula,
      alumno: fullName,
      concepto: payment.concepto,
      fechaEmision: new Date().toISOString(),
      montoBase: payment.montoOriginal,
      recargo: payment.recargo,
      total: payment.totalPagar,
      paymentId: payment.id,
    };
  }

