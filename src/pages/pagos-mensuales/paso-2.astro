  function ensureReceiptForPaid(payment: PaymentRow) {
    if (receiptsStore.has(payment.id)) {
      return;
    }

    const defaultReceipt: ReceiptData = {
      folio: `RCB-HIST-${payment.id}`,
      matricula: user.matricula,
      alumno:
        `${user.nombre} ${user.apellido_paterno} ${user.apellido_materno || ""}`.trim(),
      concepto: payment.concepto,
      fechaEmision: payment.fechaPagoISO || new Date().toISOString(),
      montoBase: payment.montoOriginal,
      recargo: payment.recargo,
      total: payment.totalPagar,
      paymentId: payment.id,
    };

    receiptsStore.set(payment.id, defaultReceipt);
  }

