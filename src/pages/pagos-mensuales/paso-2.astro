  function payCurrentMonth(paymentId: string) {
    const payment = paymentsState.find((p) => p.id === paymentId);
    if (!payment || payment.estado !== "pendiente" || payment.tieneBeca) {
      return;
    }

    payment.estado = "pagado";
    payment.fechaPagoISO = new Date().toISOString();

    const receipt = buildReceipt(payment);
    receiptsStore.set(payment.id, receipt);

    // Guardar el pago en la base de datos
    savePaymentToDB(payment, receipt).then((savedSuccessfully) => {
      if (savedSuccessfully) {
        console.log("✅ Pago guardado en BD, mostrando recibo...");
      } else {
        console.warn(
          "⚠️ El pago no se guardó en BD, pero se mostrará el recibo de todas formas",
        );
      }
      renderPaymentsData();
      openReceipt(receipt);
    });
  }

  function openStoredReceipt(paymentId: string) {
    const receipt = receiptsStore.get(paymentId);
    if (!receipt) {
      return;
    }
    openReceipt(receipt);
  }

  function loadPaymentsData(
    tieneBecaMensual: boolean = false,
    pagoMensualData: any = null,
  ) {
    paymentConfig = {
      montoBase: Number(pagoMensualData?.montoBase ?? DEFAULT_MONTO_MENSUAL),
      recargoDiario: Number(
        pagoMensualData?.recargoDiario ?? DEFAULT_RECARGO_DIARIO,
      ),
      diaLimitePago: Number(
        pagoMensualData?.diaLimitePago ?? DEFAULT_DIA_LIMITE,
      ),
    };

    const freshRows = buildPaymentRows(tieneBecaMensual);
    paymentsState.splice(0, paymentsState.length, ...freshRows);
    renderPaymentsData();
  }

  // Función para cargar datos académicos del SIGE
  async function loadAcademicData() {
    try {
      console.log("📊 Cargando datos académicos del SIGE...");

      const response = await fetch(
        `/api/sige/academic-data?matricula=${user.matricula}`,
      );

      if (!response.ok) {
        throw new Error("No se pudieron cargar los datos académicos");
      }

      const data = await response.json();

      if (data.success && data.academico) {
        console.log("✅ Datos académicos cargados:", data);

        // Actualizar badge de fuente de datos a SIGE
        const dataSourceBadge = document.getElementById("data-source-badge");
        const dataSourceText = document.getElementById("data-source-text");
        if (dataSourceBadge && dataSourceText) {
          dataSourceBadge.classList.remove(
            "bg-blue-100",
            "dark:bg-blue-900/20",
            "text-blue-700",
            "dark:text-blue-400",
            "border-blue-200",
            "dark:border-blue-800",
          );
          dataSourceBadge.classList.add(
            "bg-green-100",
            "dark:bg-green-900/20",
            "text-green-700",
            "dark:text-green-400",
            "border",
            "border-green-200",
            "dark:border-green-800",
          );
          dataSourceText.textContent = "Datos del SIGE";
        }

        const promedioHistorico = Number(
          data.academico.promedioGeneralHistorico ??
            data.academico.promedioGeneral ??
            0,
        );
        const promedioMes = Number(
          data.academico.promedioUnidadesMes ?? promedioHistorico,
        );
        const totalUnidadesMes = Number(data.academico.totalUnidadesMes ?? 0);
        const tieneBecaMensual = Boolean(
          data.academico.tieneBecaAcademicaMensual ??
          data.academico.tieneBecaAcademica,
        );

        // Actualizar información con el cálculo mensual de unidades
        updateStudentInfo({
          promedioHistorico,
          promedioMes,
          totalUnidadesMes,
          tieneBecaMensual,
        });

        // Actualizar tabla de pagos con información de beca
        loadPaymentsData(tieneBecaMensual, data.pagoMensual);

        // Mostrar calificaciones del mes para corte de caja
        const unidadesMes = Array.isArray(data.academico.unidadesEvaluadasMes)
          ? (data.academico.unidadesEvaluadasMes as UnidadEvaluadaMes[])
          : [];
        renderMonthlyGrades(unidadesMes, promedioMes);

        // Guardar datos académicos en sessionStorage para uso posterior
        sessionStorage.setItem("academicData", JSON.stringify(data));

        // Cargar pagos guardados en BD después de cargar datos académicos
        await loadPaymentsFromDB(user.matricula);
      } else {
        console.warn("⚠️ No hay datos del SIGE, usando datos locales");
        // Usar promedio local si no hay datos del SIGE
        const promedio = user.promedio || 0;
        updateStudentInfo({
          promedioHistorico: promedio,
          promedioMes: promedio,
          totalUnidadesMes: 0,
          tieneBecaMensual: false,
        });
        loadPaymentsData(false, null);
        renderMonthlyGrades([], promedio);

        // Intentar cargar pagos guardados incluso sin datos del SIGE
        await loadPaymentsFromDB(user.matricula);
      }
    } catch (error) {
      console.error("❌ Error cargando datos académicos:", error);
      // Fallback a datos locales
      const promedio = user.promedio || 0;
      updateStudentInfo({
        promedioHistorico: promedio,
        promedioMes: promedio,
        totalUnidadesMes: 0,
        tieneBecaMensual: false,
      });
      loadPaymentsData(false, null);
      renderMonthlyGrades([], promedio);

      // Intentar cargar pagos guardados en caso de error
      await loadPaymentsFromDB(user.matricula);
    }
  }

  // Cargar datos al iniciar
  loadAcademicData();

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    const actionButton = target.closest(
      "button[data-action]",
    ) as HTMLButtonElement | null;

    if (!actionButton) {
      return;
    }

    const action = actionButton.dataset.action;
    const paymentId = actionButton.dataset.paymentId;

    if (!action || !paymentId) {
      return;
    }

    if (action === "pay") {
      payCurrentMonth(paymentId);
    }

    if (action === "view-receipt") {
      openStoredReceipt(paymentId);
    }
  });

  // Logout functionality
  const logoutBtn = document.getElementById("logout-btn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      sessionStorage.clear();
      window.location.href = "/pagos-mensuales/paso-1";
    });
  }

  // Back button functionality
  const backBtn = document.getElementById("back-btn");
  if (backBtn) {
    backBtn.addEventListener("click", () => {
      window.location.href = "/";
    });
  }
</script>
