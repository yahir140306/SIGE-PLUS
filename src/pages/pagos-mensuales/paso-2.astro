---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="UTSH - Gestión de Pagos">
  <main class="max-w-7xl mx-auto px-4 py-6 sm:py-8 sm:px-6 lg:px-8 flex-grow">
    <!-- Styled Title with lateral lines -->
    <div class="flex items-center justify-center gap-3 sm:gap-4 mb-6 sm:mb-10">
      <div
        class="hidden sm:block h-px flex-1 bg-gradient-to-r from-transparent via-primary to-primary"
      >
      </div>
      <h1
        class="text-xl sm:text-2xl md:text-3xl font-bold text-center uppercase tracking-wider text-primary dark:text-white px-4"
      >
        Gestión de Pagos Mensuales
      </h1>
      <div
        class="hidden sm:block h-px flex-1 bg-gradient-to-l from-transparent via-primary to-primary"
      >
      </div>
    </div>

    <!-- Student Summary Card -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
      <div
        class="lg:col-span-2 bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-4 sm:p-6 flex flex-col sm:flex-row gap-4 sm:gap-6 items-center"
      >
        <div class="relative flex-shrink-0">
          <div
            id="student-photo"
            class="w-20 h-20 sm:w-24 sm:h-24 rounded-xl bg-slate-100 dark:bg-slate-800 bg-cover bg-center border-2 border-primary/20 flex items-center justify-center overflow-hidden"
          >
            <img
              id="student-photo-img"
              src=""
              alt="Foto de perfil"
              class="w-full h-full object-cover hidden"
              onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden');"
            />
            <span
              id="student-photo-icon"
              class="material-symbols-outlined text-4xl sm:text-5xl text-slate-400"
              >account_circle</span
            >
          </div>
          <div
            class="absolute -bottom-2 -right-2 bg-primary text-white text-[10px] px-2 py-0.5 sm:py-1 rounded-full font-bold"
          >
            ACTIVO
          </div>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div
            class="flex items-center justify-center sm:justify-start gap-2 mb-1 flex-wrap"
          >
            <h2
              id="student-name"
              class="text-lg sm:text-xl font-bold text-slate-900 dark:text-white"
            >
              Cargando...
            </h2>
            <span
              id="data-source-badge"
              class="hidden items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide"
            >
              <span class="material-symbols-outlined text-xs"></span>
              <span id="data-source-text"></span>
            </span>
          </div>
          <p
            id="student-info"
            class="text-slate-500 dark:text-slate-400 text-xs sm:text-sm mb-2 sm:mb-3"
          >
            MATRICULA: -- | --
          </p>
          <div
            class="flex flex-wrap justify-center sm:justify-start gap-2 sm:gap-3"
          >
            <span
              id="student-semester"
              class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200"
            >
              Cuatrimestre: --
            </span>
            <span
              id="student-group"
              class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-200"
            >
              Grupo: --
            </span>
            <span
              id="student-average"
              class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20"
            >
              Promedio: --
            </span>
          </div>
        </div>
        <div
          class="flex flex-col sm:flex-row lg:flex-col gap-2 w-full sm:w-auto"
        >
          <button
            class="flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-semibold transition-all"
          >
            <span class="material-symbols-outlined text-sm"></span>
            Estado de Cuenta
          </button>
          <button
            id="logout-btn"
            class="flex items-center justify-center gap-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-semibold transition-all"
          >
            <span class="material-symbols-outlined text-sm"></span>
            Cerrar Sesión
          </button>
        </div>
      </div>

      <!-- GPA Alert Card -->
      <div
        id="gpa-alert"
        class="bg-secondary/5 dark:bg-secondary/10 rounded-xl border border-secondary/20 p-4 sm:p-6 flex flex-col justify-center"
      >
        <div class="flex items-start gap-3 sm:gap-4">
          <div
            class="bg-secondary/20 p-2 rounded-lg text-secondary flex-shrink-0"
          >
            <span class="material-symbols-outlined text-base sm:text-xl"></span>
          </div>
          <div>
            <h3 class="font-bold text-secondary mb-1 text-xs sm:text-sm">
              Aviso de Beca
            </h3>
            <p
              id="gpa-message"
              class="text-[11px] sm:text-xs text-slate-600 dark:text-slate-400 leading-relaxed"
            >
              Cargando información...
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment Table Container -->
    <div
      class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden"
    >
      <div
        class="px-4 sm:px-6 py-3 sm:py-4 border-b border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
      >
        <h3
          class="font-bold text-base sm:text-lg text-slate-800 dark:text-slate-100"
        >
          Periodo: Enero - Abril 2026
        </h3>
        <div
          class="flex items-center gap-2 text-[11px] sm:text-xs font-medium text-slate-500"
        >
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span id="paid-count">0</span> Pagados
          <span class="w-2 h-2 rounded-full bg-secondary ml-2"></span>
          <span id="pending-count">0</span> Pendientes
        </div>
      </div>

      <!-- Desktop Table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-slate-50 dark:bg-slate-800/50">
            <tr>
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider"
                >Mes de Pago</th
              >
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider"
                >Fecha Límite</th
              >
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider"
                >Concepto</th
              >
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider"
                >Monto</th
              >
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-center"
                >Estatus</th
              >
              <th
                class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider text-right"
                >Acción</th
              >
            </tr>
          </thead>
          <tbody
            id="payments-table"
            class="divide-y divide-slate-100 dark:divide-slate-800"
          >
            <!-- Payments will be loaded here dynamically -->
          </tbody>
        </table>
      </div>

      <!-- Mobile Cards -->
      <div
        id="payments-mobile"
        class="md:hidden divide-y divide-slate-100 dark:divide-slate-800"
      >
        <!-- Payment cards will be loaded here dynamically -->
      </div>
    </div>

    <!-- Additional Info / Support -->
    <div class="mt-6 sm:mt-8 flex flex-col md:flex-row gap-4 sm:gap-6">
      <div
        class="flex-1 bg-maroon/5 dark:bg-maroon/10 rounded-xl p-4 sm:p-6 border border-maroon/10"
      >
        <div class="flex gap-3 sm:gap-4">
          <span
            class="material-symbols-outlined text-maroon text-xl sm:text-2xl flex-shrink-0"
          ></span>
          <div>
            <h4 class="font-bold text-maroon text-xs sm:text-sm mb-1">
              ¿Dudas con tus pagos?
            </h4>
            <p
              class="text-[11px] sm:text-xs text-slate-600 dark:text-slate-400 mb-2 sm:mb-3 leading-relaxed"
            >
              Si has realizado un pago y no se refleja en el sistema, favor de
              acudir a la oficina de finanzas con tu comprobante original.
            </p>
            <a
              class="text-[11px] sm:text-xs font-bold text-maroon underline"
              href="#">Contactar a soporte</a
            >
          </div>
        </div>
      </div>
      <div
        class="flex-1 bg-slate-100 dark:bg-slate-800/50 rounded-xl p-4 sm:p-6 border border-slate-200 dark:border-slate-700"
      >
        <div class="flex gap-3 sm:gap-4">
          <span
            class="material-symbols-outlined text-slate-500 text-xl sm:text-2xl flex-shrink-0"
          ></span>
          <div>
            <h4
              class="font-bold text-slate-700 dark:text-slate-300 text-xs sm:text-sm mb-1"
            >
              Métodos de Pago
            </h4>
            <p
              class="text-[11px] sm:text-xs text-slate-600 dark:text-slate-400 mb-2 sm:mb-3 leading-relaxed"
            >
              Puedes realizar tu pago en ventanilla bancaria (BBVA), cajeros
              inteligentes o vía transferencia electrónica con tu referencia
              única.
            </p>
            <div class="flex gap-2">
              <div
                class="h-6 w-10 bg-white dark:bg-slate-700 rounded border border-slate-200 dark:border-slate-600 flex items-center justify-center text-[10px] font-bold text-slate-400"
              >
                VISA
              </div>
              <div
                class="h-6 w-10 bg-white dark:bg-slate-700 rounded border border-slate-200 dark:border-slate-600 flex items-center justify-center text-[10px] font-bold text-slate-400"
              >
                MC
              </div>
              <div
                class="h-6 w-10 bg-white dark:bg-slate-700 rounded border border-slate-200 dark:border-slate-600 flex items-center justify-center text-[10px] font-bold text-slate-400"
              >
                SPEI
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Back Button -->
    <div class="mt-6 sm:mt-8 text-center">
      <button
        id="back-btn"
        class="inline-flex items-center gap-2 px-4 sm:px-6 py-2 sm:py-3 rounded-lg border-2 border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-sm sm:text-base"
      >
        <span class="material-symbols-outlined text-base"></span>
        Regresar
      </button>
    </div>
  </main>
</Layout>

<script>
  // Check if user is logged in
  const userStr = sessionStorage.getItem("user");
  if (!userStr) {
    window.location.href = "/pagos-mensuales/paso-1";
    throw new Error("No user session");
  }

  const user = JSON.parse(userStr);

  // Migrar URL de foto antigua (HTTP directo) a proxy API
  if (
    user.foto_url &&
    user.foto_url.startsWith("http://sige.utsh.edu.mx/ctrlfotos/")
  ) {
    const matricula = user.matricula;
    user.foto_url = `/api/sige/proxy-image?matricula=${matricula}`;
    sessionStorage.setItem("user", JSON.stringify(user));
  } else if (
    user.foto_url &&
    user.foto_url.startsWith("https://sige.utsh.edu.mx/ctrlfotos/")
  ) {
    const matricula = user.matricula;
    user.foto_url = `/api/sige/proxy-image?matricula=${matricula}`;
    sessionStorage.setItem("user", JSON.stringify(user));
  }

  // Get data source
  const dataSource = sessionStorage.getItem("dataSource") || "database";

  // Show data source badge
  const dataSourceBadge = document.getElementById("data-source-badge");
  const dataSourceText = document.getElementById("data-source-text");
  if (dataSourceBadge && dataSourceText) {
    dataSourceBadge.classList.remove("hidden");
    dataSourceBadge.classList.add("inline-flex");
    if (dataSource === "portal" || dataSource === "sige") {
      dataSourceBadge.classList.add(
        "bg-green-100",
        "dark:bg-green-900/20",
        "text-green-700",
        "dark:text-green-400",
        "border",
        "border-green-200",
        "dark:border-green-800",
      );
      dataSourceText.textContent = "Portal Oficial";
    } else {
      dataSourceBadge.classList.add(
        "bg-blue-100",
        "dark:bg-blue-900/20",
        "text-blue-700",
        "dark:text-blue-400",
        "border",
        "border-blue-200",
        "dark:border-blue-800",
      );
      dataSourceText.textContent = "Base de Datos";
    }
  }

  // Función para actualizar la información del estudiante
  function updateStudentInfo(promedio: number) {
    const studentName = document.getElementById("student-name");
    const studentInfo = document.getElementById("student-info");
    const studentSemester = document.getElementById("student-semester");
    const studentGroup = document.getElementById("student-group");
    const studentAverage = document.getElementById("student-average");
    const studentPhotoImg = document.getElementById(
      "student-photo-img",
    ) as HTMLImageElement;
    const gpaMessage = document.getElementById("gpa-message");
    const gpaAlert = document.getElementById("gpa-alert");

    if (studentName && studentInfo && studentSemester && studentAverage) {
      const fullName =
        `${user.nombre} ${user.apellido_paterno} ${user.apellido_materno || ""}`.trim();
      studentName.textContent = fullName;

      const carreraName = user.carrera?.nombre || "Carrera no especificada";
      studentInfo.textContent = `Matricula: ${user.matricula} | ${carreraName}`;

      const cuatrimestreValue =
        user.cuatrimestre && user.cuatrimestre > 0 ? user.cuatrimestre : "--";
      studentSemester.textContent = `Cuatrimestre: ${cuatrimestreValue}`;

      if (studentGroup) {
        const grupoValue = user.grupo || "--";
        studentGroup.textContent = `Grupo: ${grupoValue}`;
      }

      studentAverage.textContent = `Promedio: ${promedio.toFixed(2)}`;

      // Update student photo
      if (studentPhotoImg && user.foto_url) {
        const studentPhotoIcon = document.getElementById("student-photo-icon");

        console.log("🖼️ Cargando foto desde:", user.foto_url);

        // Configurar manejadores antes de establecer src
        studentPhotoImg.onload = () => {
          console.log("✅ Foto cargada exitosamente");
          studentPhotoImg.classList.remove("hidden");
          if (studentPhotoIcon) {
            studentPhotoIcon.classList.add("hidden");
          }
        };

        studentPhotoImg.onerror = () => {
          console.warn("⚠️ Error al cargar foto, mostrando icono por defecto");
          studentPhotoImg.classList.add("hidden");
          if (studentPhotoIcon) {
            studentPhotoIcon.classList.remove("hidden");
          }
        };

        // Establecer src para iniciar la carga
        studentPhotoImg.src = user.foto_url;
      }

      // Update GPA message
      if (gpaMessage && gpaAlert) {
        if (promedio >= 9.0) {
          gpaAlert.classList.remove(
            "bg-secondary/5",
            "dark:bg-secondary/10",
            "border-secondary/20",
          );
          gpaAlert.classList.add(
            "bg-primary/5",
            "dark:bg-primary/10",
            "border-primary/20",
          );
          gpaAlert
            .querySelector(".bg-secondary\\/20")
            ?.classList.remove("bg-secondary/20", "text-secondary");
          gpaAlert
            .querySelector(".bg-secondary\\/20")
            ?.classList.add("bg-primary/20", "text-primary");
          gpaAlert
            .querySelector(".text-secondary")
            ?.classList.remove("text-secondary");
          gpaAlert
            .querySelector(".text-secondary")
            ?.classList.add("text-primary");
          gpaMessage.innerHTML = `¡Felicidades! Tu promedio actual es de <b>${promedio.toFixed(2)}</b>. Tienes derecho a <b>BECA ACADÉMICA</b> del 100% en tus pagos mensuales este cuatrimestre.`;
        } else {
          gpaMessage.innerHTML = `Tu promedio actual es de <b>${promedio.toFixed(2)}</b>. Para obtener la beca académica del 100%, necesitas un promedio de 9.0 o superior.`;
        }
      }
    }
  }

  // Función para cargar datos académicos del SIGE
  async function loadAcademicData() {
    try {
      console.log("📊 Cargando datos académicos del SIGE...");

      const response = await fetch(
        `/api/sige/academic-data?matricula=${user.matricula}`,
      );

      if (!response.ok) {
        throw new Error("No se pudieron cargar los datos académicos");
      }

      const data = await response.json();

      if (data.success && data.academico) {
        console.log("✅ Datos académicos cargados:", data);

        // Actualizar badge de fuente de datos a SIGE
        const dataSourceBadge = document.getElementById("data-source-badge");
        const dataSourceText = document.getElementById("data-source-text");
        if (dataSourceBadge && dataSourceText) {
          dataSourceBadge.classList.remove(
            "bg-blue-100",
            "dark:bg-blue-900/20",
            "text-blue-700",
            "dark:text-blue-400",
            "border-blue-200",
            "dark:border-blue-800",
          );
          dataSourceBadge.classList.add(
            "bg-green-100",
            "dark:bg-green-900/20",
            "text-green-700",
            "dark:text-green-400",
            "border",
            "border-green-200",
            "dark:border-green-800",
          );
          dataSourceText.textContent = "Datos del SIGE";
        }

        // Actualizar información con el promedio real del SIGE
        updateStudentInfo(data.academico.promedioGeneral);

        // Actualizar tabla de pagos con información de beca
        loadPaymentsData(data.academico.tieneBecaAcademica);

        // Guardar datos académicos en sessionStorage para uso posterior
        sessionStorage.setItem("academicData", JSON.stringify(data));
      } else {
        console.warn("⚠️ No hay datos del SIGE, usando datos locales");
        // Usar promedio local si no hay datos del SIGE
        const promedio = user.promedio || 0;
        updateStudentInfo(promedio);
        loadPaymentsData(promedio >= 9.0);
      }
    } catch (error) {
      console.error("❌ Error cargando datos académicos:", error);
      // Fallback a datos locales
      const promedio = user.promedio || 0;
      updateStudentInfo(promedio);
      loadPaymentsData(promedio >= 9.0);
    }
  }

  // Cargar datos al iniciar
  loadAcademicData();

  // Load payments data
  function loadPaymentsData(tieneBeca: boolean = false) {
    const montoBase = 2450;
    const montoConBeca = tieneBeca ? 0 : montoBase; // 100% de descuento si tiene beca

    const paymentsData = [
      {
        mes: "Enero",
        fecha: "15 / Ene / 2026",
        concepto: "Mensualidad #1",
        monto: montoConBeca,
        montoOriginal: montoBase,
        estado: "pagado",
        tieneBeca: tieneBeca,
      },
      {
        mes: "Febrero",
        fecha: "15 / Feb / 2026",
        concepto: "Mensualidad #2",
        monto: montoConBeca,
        montoOriginal: montoBase,
        estado: "pagado",
        tieneBeca: tieneBeca,
      },
      {
        mes: "Marzo",
        fecha: "15 / Mar / 2026",
        concepto: "Mensualidad #3",
        monto: montoConBeca,
        montoOriginal: montoBase,
        estado: "pendiente",
        tieneBeca: tieneBeca,
      },
      {
        mes: "Abril",
        fecha: "15 / Abr / 2026",
        concepto: "Mensualidad #4",
        monto: montoConBeca,
        montoOriginal: montoBase,
        estado: "proximo",
        tieneBeca: tieneBeca,
      },
    ];

    // Count payments
    const paidCount = paymentsData.filter((p) => p.estado === "pagado").length;
    const pendingCount = paymentsData.filter(
      (p) => p.estado === "pendiente",
    ).length;

    const paidCountEl = document.getElementById("paid-count");
    const pendingCountEl = document.getElementById("pending-count");
    if (paidCountEl) paidCountEl.textContent = String(paidCount);
    if (pendingCountEl) pendingCountEl.textContent = String(pendingCount);

    // Render desktop table
    const paymentsTable = document.getElementById("payments-table");
    if (paymentsTable) {
      paymentsTable.innerHTML = paymentsData
        .map((payment) => {
          let statusHtml = "";
          let actionHtml = "";
          let montoHtml = "";

          if (payment.tieneBeca) {
            montoHtml = `
              <div class="flex flex-col items-start">
                <span class="text-xs text-slate-400 line-through">$${payment.montoOriginal.toFixed(2)}</span>
                <span class="font-bold text-primary">$0.00</span>
                <span class="text-[10px] text-primary font-bold">BECA 100%</span>
              </div>
            `;
          } else {
            montoHtml = `<span class="font-bold text-slate-900 dark:text-slate-100">$${payment.monto.toFixed(2)}</span>`;
          }

          if (payment.estado === "pagado") {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary border border-primary/20">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PAGADO
            </span>
          `;
            actionHtml = `
            <button class="text-secondary hover:text-secondary/80 font-bold text-xs flex items-center gap-1 ml-auto transition-colors">
              <span class="material-symbols-outlined text-sm"></span>
              Ver Recibo
            </button>
          `;
          } else if (payment.estado === "pendiente") {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-secondary/10 text-secondary border border-secondary/20">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PENDIENTE
            </span>
          `;
            if (payment.tieneBeca) {
              actionHtml = `
                <button class="bg-primary hover:bg-primary/90 text-white px-4 py-1.5 rounded-lg text-xs font-bold transition-all shadow-sm">
                  Confirmar Matrícula
                </button>
              `;
            } else {
              actionHtml = `
                <button class="bg-maroon hover:bg-maroon/90 text-white px-4 py-1.5 rounded-lg text-xs font-bold transition-all shadow-sm">
                  Generar Referencia
                </button>
              `;
            }
          } else {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-500 border border-slate-200 dark:border-slate-700">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PRÓXIMO
            </span>
          `;
            actionHtml = `
            <button class="bg-slate-200 dark:bg-slate-800 text-slate-400 dark:text-slate-600 px-4 py-1.5 rounded-lg text-xs font-bold cursor-not-allowed" disabled>
              Generar Referencia
            </button>
          `;
          }

          return `
          <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
            <td class="px-6 py-4">
              <span class="font-semibold text-slate-900 dark:text-slate-100">${payment.mes}</span>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500">${payment.fecha}</td>
            <td class="px-6 py-4 text-sm text-slate-500">${payment.concepto}</td>
            <td class="px-6 py-4">${montoHtml}</td>
            <td class="px-6 py-4 text-center">${statusHtml}</td>
            <td class="px-6 py-4 text-right">${actionHtml}</td>
          </tr>
        `;
        })
        .join("");
    }

    // Render mobile cards
    const paymentsMobile = document.getElementById("payments-mobile");
    if (paymentsMobile) {
      paymentsMobile.innerHTML = paymentsData
        .map((payment) => {
          let statusHtml = "";
          let actionHtml = "";
          let montoHtml = "";

          if (payment.tieneBeca) {
            montoHtml = `
              <div class="flex flex-col items-end">
                <span class="text-xs text-slate-400 line-through">$${payment.montoOriginal.toFixed(2)}</span>
                <span class="font-bold text-primary">$0.00</span>
                <span class="text-[10px] text-primary font-bold">BECA 100%</span>
              </div>
            `;
          } else {
            montoHtml = `<span class="font-bold text-slate-900 dark:text-slate-100">$${payment.monto.toFixed(2)}</span>`;
          }

          if (payment.estado === "pagado") {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary border border-primary/20">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PAGADO
            </span>
          `;
            actionHtml = `
            <button class="w-full text-secondary hover:text-secondary/80 font-bold text-xs flex items-center justify-center gap-2 py-2 transition-colors">
              <span class="material-symbols-outlined text-sm"></span>
              Ver Recibo
            </button>
          `;
          } else if (payment.estado === "pendiente") {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-secondary/10 text-secondary border border-secondary/20">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PENDIENTE
            </span>
          `;
            if (payment.tieneBeca) {
              actionHtml = `
                <button class="w-full bg-primary hover:bg-primary/90 text-white py-2 rounded-lg text-xs font-bold transition-all shadow-sm">
                  Confirmar Matrícula
                </button>
              `;
            } else {
              actionHtml = `
                <button class="w-full bg-maroon hover:bg-maroon/90 text-white py-2 rounded-lg text-xs font-bold transition-all shadow-sm">
                  Generar Referencia
                </button>
              `;
            }
          } else {
            statusHtml = `
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-500 border border-slate-200 dark:border-slate-700">
              <span class="material-symbols-outlined text-[14px] font-bold"></span>
              PRÓXIMO
            </span>
          `;
            actionHtml = `
            <button class="w-full bg-slate-200 dark:bg-slate-800 text-slate-400 dark:text-slate-600 py-2 rounded-lg text-xs font-bold cursor-not-allowed" disabled>
              Generar Referencia
            </button>
          `;
          }

          return `
          <div class="p-4 hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
            <div class="flex justify-between items-start mb-3">
              <div>
                <h4 class="font-semibold text-slate-900 dark:text-slate-100 text-sm">${payment.mes}</h4>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">${payment.fecha}</p>
              </div>
              ${statusHtml}
            </div>
            <div class="space-y-2 mb-3">
              <div class="flex justify-between text-xs">
                <span class="text-slate-500 dark:text-slate-400">Concepto:</span>
                <span class="text-slate-700 dark:text-slate-300">${payment.concepto}</span>
              </div>
              <div class="flex justify-between text-xs items-end">
                <span class="text-slate-500 dark:text-slate-400">Monto:</span>
                ${montoHtml}
              </div>
            </div>
            ${actionHtml}
          </div>
        `;
        })
        .join("");
    }
  }

  // Logout functionality
  const logoutBtn = document.getElementById("logout-btn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", () => {
      sessionStorage.clear();
      window.location.href = "/pagos-mensuales/paso-1";
    });
  }

  // Back button functionality
  const backBtn = document.getElementById("back-btn");
  if (backBtn) {
    backBtn.addEventListener("click", () => {
      window.location.href = "/";
    });
  }
</script>
