---
import Layout from "../layouts/Layout.astro";
---

<Layout title="UTSH - Iniciar Sesión en Portal Oficial">
  <main
    class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 py-12 px-4"
  >
    <div class="max-w-6xl mx-auto">
      <!-- Instrucciones -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 mb-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            <span class="material-symbols-outlined text-4xl text-primary"
              >info</span
            >
          </div>
          <div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">
              Acceso al Portal Oficial SIGE
            </h2>
            <p class="text-slate-600 dark:text-slate-300 mb-4">
              Para tu seguridad, inicia sesión directamente en el portal oficial
              de la UTSH. Una vez que inicies sesión exitosamente, tus datos
              serán sincronizados automáticamente con nuestra plataforma.
            </p>
            <div
              class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4"
            >
              <p class="text-sm text-blue-800 dark:text-blue-200">
                <strong>Instrucciones:</strong>
              </p>
              <ol
                class="list-decimal list-inside text-sm text-blue-700 dark:text-blue-300 mt-2 space-y-1"
              >
                <li>
                  Haz clic en el botón "Abrir Portal SIGE" para abrir una
                  ventana nueva
                </li>
                <li>
                  Inicia sesión con tu matrícula y contraseña en el portal
                  oficial
                </li>
                <li>Regresa a esta página y haz clic en "Sincronizar Datos"</li>
                <li>Tus datos se importarán automáticamente de forma segura</li>
              </ol>
            </div>
          </div>
        </div>
      </div>

      <!-- Estado de la sincronización -->
      <div id="sync-status" class="hidden mb-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-6">
          <div class="flex items-center gap-4">
            <div class="animate-spin"></div>
            <div>
              <h3 class="text-lg font-semibold text-slate-900 dark:text-white">
                Sincronizando datos...
              </h3>
              <p
                class="text-sm text-slate-600 dark:text-slate-400"
                id="sync-message"
              >
                Extrayendo información del portal SIGE
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Alert -->
      <div id="alert-container" class="hidden mb-6">
        <div id="alert" class="rounded-2xl shadow-xl p-6">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-3xl" id="alert-icon"
            ></span>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-2" id="alert-title"></h3>
              <p class="text-sm" id="alert-message"></p>
            </div>
            <button
              onclick="document.getElementById('alert-container').classList.add('hidden')"
              class="text-slate-400 hover:text-slate-600"
            >
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Panel de Control -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8">
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Opción 1: Abrir Portal -->
          <div
            class="border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-xl p-6 hover:border-primary transition-colors"
          >
            <div class="text-center">
              <div
                class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-4"
              >
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">
                Paso 1: Abrir Portal
              </h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
                Abre el portal oficial del SIGE en una nueva ventana e inicia
                sesión normalmente
              </p>
              <button
                id="btn-open-portal"
                class="w-full bg-primary hover:bg-primary/90 text-white font-semibold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2"
              >
                <span class="material-symbols-outlined">launch</span>
                Abrir Portal SIGE
              </button>
            </div>
          </div>

          <!-- Opción 2: Sincronizar -->
          <div
            class="border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-xl p-6 hover:border-primary transition-colors"
          >
            <div class="text-center">
              <div
                class="inline-flex items-center justify-center w-16 h-16 bg-green-500/10 rounded-full mb-4"
              >
              </div>
              <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">
                Paso 2: Sincronizar
              </h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
                Después de iniciar sesión en el portal, sincroniza tus datos
                aquí
              </p>
              <button
                id="btn-sync"
                class="w-full bg-green-500 hover:bg-green-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2"
              >
                <span class="material-symbols-outlined">download</span>
                Sincronizar Datos
              </button>
            </div>
          </div>
        </div>

        <!-- Método alternativo -->
        <div class="mt-8 pt-8 border-t border-slate-200 dark:border-slate-700">
          <details class="group">
            <summary
              class="cursor-pointer flex items-center justify-between text-slate-700 dark:text-slate-300 font-medium"
            >
              <span>💡 Método alternativo (para usuarios avanzados)</span>
              <span
                class="material-symbols-outlined group-open:rotate-180 transition-transform"
              >
                expand_more
              </span>
            </summary>
            <div class="mt-4 bg-slate-50 dark:bg-slate-900/50 rounded-lg p-4">
              <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">
                Si ya iniciaste sesión en el portal SIGE en otra pestaña, puedes
                copiar tu cookie de sesión:
              </p>
              <ol
                class="list-decimal list-inside text-sm text-slate-600 dark:text-slate-400 space-y-2 mb-4"
              >
                <li>Abre el portal SIGE en otra pestaña e inicia sesión</li>
                <li>
                  Presiona <kbd
                    class="px-2 py-1 bg-slate-200 dark:bg-slate-700 rounded"
                    >F12</kbd
                  > para abrir DevTools
                </li>
                <li>
                  En la consola, escribe: <code
                    class="bg-slate-200 dark:bg-slate-700 px-2 py-1 rounded"
                    >document.cookie</code
                  >
                </li>
                <li>Copia el valor de <strong>PHPSESSID</strong></li>
                <li>Pégalo aquí abajo:</li>
              </ol>
              <div class="flex gap-2">
                <input
                  type="text"
                  id="manual-cookie"
                  placeholder="PHPSESSID=k4u7stltn6f3ch8cv30601ll62"
                  class="flex-1 px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-primary text-sm font-mono"
                />
                <button
                  id="btn-manual-sync"
                  class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded-lg font-medium"
                >
                  Usar Cookie
                </button>
              </div>
            </div>
          </details>
        </div>
      </div>

      <!-- Información de seguridad -->
      <div class="mt-6 text-center text-sm text-slate-500 dark:text-slate-400">
        <p class="flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-lg">lock</span>
          Tus datos están protegidos y encriptados. Nunca almacenamos tu contraseña.
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  // URLs
  const SIGE_URL = "http://sige.utsh.edu.mx/estudiantes/";
  const EXTRACT_API = "/api/sige/extract-data";
  const SAVE_API = "/api/sige/save-to-db";

  // Obtener parámetro de redirección de la URL
  const urlParams = new URLSearchParams(window.location.search);
  const redirectUrl = urlParams.get("redirect") || "/";

  let sigeWindow: Window | null = null;

  // Elementos del DOM
  const btnOpenPortal = document.getElementById("btn-open-portal");
  const btnSync = document.getElementById("btn-sync");
  const btnManualSync = document.getElementById("btn-manual-sync");
  // prettier-ignore
  const manualCookieInput = document.getElementById("manual-cookie") as HTMLInputElement;
  const syncStatus = document.getElementById("sync-status");
  const syncMessage = document.getElementById("sync-message");
  const alertContainer = document.getElementById("alert-container");

  /**
   * Muestra una alerta
   */
  function showAlert(
    type: "success" | "error" | "warning",
    title: string,
    message: string,
  ) {
    const alert = document.getElementById("alert");
    const icon = document.getElementById("alert-icon");
    const titleEl = document.getElementById("alert-title");
    const messageEl = document.getElementById("alert-message");

    // Validar que todos los elementos existan
    if (!alert || !icon || !titleEl || !messageEl) {
      return;
    }

    // Configurar estilos según el tipo
    if (type === "success") {
      alert.className =
        "rounded-2xl shadow-xl p-6 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800";
      icon.className = "material-symbols-outlined text-3xl text-green-500";
      icon.textContent = "check_circle";
      titleEl.className =
        "text-lg font-semibold mb-2 text-green-800 dark:text-green-200";
      messageEl.className = "text-sm text-green-700 dark:text-green-300";
    } else if (type === "error") {
      alert.className =
        "rounded-2xl shadow-xl p-6 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800";
      icon.className = "material-symbols-outlined text-3xl text-red-500";
      icon.textContent = "error";
      titleEl.className =
        "text-lg font-semibold mb-2 text-red-800 dark:text-red-200";
      messageEl.className = "text-sm text-red-700 dark:text-red-300";
    } else {
      alert.className =
        "rounded-2xl shadow-xl p-6 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800";
      icon.className = "material-symbols-outlined text-3xl text-yellow-500";
      icon.textContent = "warning";
      titleEl.className =
        "text-lg font-semibold mb-2 text-yellow-800 dark:text-yellow-200";
      messageEl.className = "text-sm text-yellow-700 dark:text-yellow-300";
    }

    titleEl.textContent = title;
    messageEl.textContent = message;

    if (alertContainer) {
      alertContainer.classList.remove("hidden");
    }
  }

  /**
   * Abre el portal SIGE en una nueva ventana
   */
  btnOpenPortal?.addEventListener("click", () => {
    sigeWindow = window.open(
      SIGE_URL,
      "SIGE_Portal",
      "width=1200,height=800,menubar=no,toolbar=no,location=yes",
    );

    if (sigeWindow) {
      showAlert(
        "success",
        "Portal abierto",
        "Se ha abierto el portal SIGE. Inicia sesión y regresa aquí para sincronizar tus datos.",
      );
    } else {
      showAlert(
        "warning",
        "Ventana bloqueada",
        "Tu navegador bloqueó la ventana emergente. Por favor, permite las ventanas emergentes y vuelve a intentar.",
      );
    }
  });

  /**
   * Intenta obtener la cookie del portal SIGE sin abrir ventanas
   * NOTA: Esto NO funcionará por CORS, pero lo dejo como ejemplo
   */
  async function getCookieFromSige(): Promise<string | null> {
    try {
      // Crear un iframe oculto temporal
      const iframe = document.createElement("iframe");
      iframe.style.display = "none";
      iframe.src = SIGE_URL;
      document.body.appendChild(iframe);

      // Esperar a que cargue
      await new Promise((resolve) => {
        iframe.onload = resolve;
        setTimeout(resolve, 3000); // Timeout de seguridad
      });

      // Intentar leer la cookie (NO FUNCIONARÁ por CORS/SameSite)
      // Este código está aquí solo como referencia de lo que NO se puede hacer
      let cookie = null;
      try {
        cookie = iframe.contentDocument?.cookie;
      } catch (e) {
        // No se puede acceder a cookies por CORS (esperado)
      }

      document.body.removeChild(iframe);
      return cookie || null;
    } catch (error) {
      // Error obteniendo cookie
      return null;
    }
  }

  /**
   * Extrae el PHPSESSID de una cadena de cookie
   */
  function extractPHPSESSID(cookieString: string): string | null {
    const match = cookieString.match(/PHPSESSID=([^;]+)/);
    return match ? match[1] : null;
  }

  /**
   * Sincroniza los datos usando la cookie
   */
  async function syncData(phpsessid: string, matricula?: string) {
    try {
      // Mostrar estado de sincronización
      if (syncStatus) {
        syncStatus.classList.remove("hidden");
      }
      if (alertContainer) {
        alertContainer.classList.add("hidden");
      }

      // 1. Extraer datos del SIGE
      if (syncMessage) {
        syncMessage.textContent = "Extrayendo datos del portal SIGE...";
      }

      const extractResponse = await fetch(EXTRACT_API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ phpsessid, matricula }),
      });

      if (!extractResponse.ok) {
        const error = await extractResponse.json();
        throw new Error(error.error || "Error al extraer datos");
      }

      const extractData = await extractResponse.json();

      if (!extractData.success) {
        throw new Error("No se pudieron extraer los datos del SIGE");
      }

      // Datos extraídos exitosamente

      // 2. Guardar en base de datos
      if (syncMessage) {
        syncMessage.textContent = "Guardando datos en la base de datos...";
      }

      const saveResponse = await fetch(SAVE_API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          data: extractData.data,
          matricula: extractData.matricula,
        }),
      });

      if (!saveResponse.ok) {
        const error = await saveResponse.json();
        throw new Error(error.error || "Error al guardar datos");
      }

      const saveData = await saveResponse.json();
      // Datos guardados exitosamente

      // Ocultar sync status
      if (syncStatus) {
        syncStatus.classList.add("hidden");
      }

      // Preparar datos para sessionStorage
      const datosPersonales = extractData.data.datosPersonales;
      const historialAcademico = extractData.data.historialAcademico;
      const calificacionesActuales = extractData.data.calificacionesActuales;
      const adeudos = extractData.data.adeudos;

      // Construir URL de la foto usando la matrícula (usar HTTPS para evitar mixed content)
      const fotoUrl = `https://sige.utsh.edu.mx/ctrlfotos/${extractData.matricula}.jpg`;

      // Extraer nombre, apellidos del nombreCompleto
      const nombreCompleto = datosPersonales?.nombreCompleto || "";
      const partesNombre = nombreCompleto.split(" ");

      // Parsear cuatrimestre - puede venir como "1", "1ro", "Primero", etc.
      const cuatrimestreStr = datosPersonales?.cuatrimestre || "";
      let cuatrimestreNum = 0;

      // Intentar extraer el número del string de cuatrimestre
      const cuatrimestreMatch = cuatrimestreStr.match(/\d+/);
      if (cuatrimestreMatch) {
        cuatrimestreNum = parseInt(cuatrimestreMatch[0]);
      } else if (cuatrimestreStr.toLowerCase().includes("primer")) {
        cuatrimestreNum = 1;
      } else if (cuatrimestreStr.toLowerCase().includes("segundo")) {
        cuatrimestreNum = 2;
      } else if (cuatrimestreStr.toLowerCase().includes("tercer")) {
        cuatrimestreNum = 3;
      } else if (cuatrimestreStr.toLowerCase().includes("cuarto")) {
        cuatrimestreNum = 4;
      } else if (cuatrimestreStr.toLowerCase().includes("quinto")) {
        cuatrimestreNum = 5;
      } else if (cuatrimestreStr.toLowerCase().includes("sexto")) {
        cuatrimestreNum = 6;
      } else if (
        cuatrimestreStr.toLowerCase().includes("séptimo") ||
        cuatrimestreStr.toLowerCase().includes("septimo")
      ) {
        cuatrimestreNum = 7;
      } else if (cuatrimestreStr.toLowerCase().includes("octavo")) {
        cuatrimestreNum = 8;
      } else if (cuatrimestreStr.toLowerCase().includes("noveno")) {
        cuatrimestreNum = 9;
      } else if (
        cuatrimestreStr.toLowerCase().includes("décimo") ||
        cuatrimestreStr.toLowerCase().includes("decimo")
      ) {
        cuatrimestreNum = 10;
      }

      // Guardar datos en sessionStorage en formato compatible con las páginas existentes
      const userData = {
        matricula: extractData.matricula,
        nombre: partesNombre[0] || "",
        apellido_paterno: partesNombre[1] || "",
        apellido_materno: partesNombre[2] || "",
        curp: datosPersonales?.curp || "",
        carrera: {
          nombre: datosPersonales?.carrera || "No disponible",
        },
        periodo: {
          nombre: datosPersonales?.periodoActivo || "No disponible",
        },
        cuatrimestre: cuatrimestreNum,
        promedio: historialAcademico?.promedioGeneral || 0,
        foto_url: fotoUrl,
        grupo: datosPersonales?.grupo || "",
        estatus: datosPersonales?.estatus || "ACTIVO",
        tienePagosPendientes: adeudos && adeudos.length > 0,
        // Datos adicionales del SIGE
        materias: calificacionesActuales || [],
        adeudos: adeudos || [],
        historialAcademico: historialAcademico?.materias || [],
      };

      sessionStorage.setItem("user", JSON.stringify(userData));
      sessionStorage.setItem("dataSource", "sige");
      sessionStorage.setItem("academicData", JSON.stringify(extractData.data));

      // Guardar matrícula en localStorage
      localStorage.setItem("matricula", extractData.matricula);

      // Mostrar éxito
      showAlert(
        "success",
        "¡Sincronización exitosa!",
        `Datos de ${userData.nombre} ${userData.apellido_paterno} guardados correctamente. ` +
          `${saveData.resumen.materias} materias, ${saveData.resumen.calificaciones} calificaciones, ` +
          `${saveData.resumen.adeudos} adeudos.`,
      );

      // Redirigir a la página solicitada después de 2 segundos
      setTimeout(() => {
        window.location.href = redirectUrl;
      }, 2000);
    } catch (error) {
      // Error en sincronización
      if (syncStatus) {
        syncStatus.classList.add("hidden");
      }
      showAlert(
        "error",
        "Error en la sincronización",
        error instanceof Error
          ? error.message
          : "Error desconocido. Por favor, intenta nuevamente.",
      );
    }
  }

  /**
   * Botón de sincronización automática
   */
  btnSync?.addEventListener("click", async () => {
    // NOTA: Por limitaciones de seguridad del navegador (CORS, SameSite cookies),
    // NO podemos leer cookies de otro dominio desde JavaScript.
    // El usuario debe usar el método manual o una extensión del navegador.

    showAlert(
      "warning",
      "Método no disponible",
      "Por razones de seguridad, no podemos acceder automáticamente a las cookies del portal SIGE. " +
        "Por favor, usa el método alternativo copiando manualmente tu cookie de sesión.",
    );

    // Abrir el método alternativo
    const details = document.querySelector("details");
    if (details) {
      details.open = true;
      manualCookieInput.focus();
    }
  });

  /**
   * Sincronización manual con cookie
   */
  btnManualSync?.addEventListener("click", async () => {
    const cookieValue = manualCookieInput.value.trim();

    if (!cookieValue) {
      showAlert(
        "warning",
        "Cookie requerida",
        "Por favor, ingresa el valor de la cookie PHPSESSID.",
      );
      return;
    }

    // Extraer PHPSESSID si viene en formato completo
    const phpsessid = extractPHPSESSID(cookieValue) || cookieValue;

    if (!phpsessid || phpsessid.length < 10) {
      showAlert(
        "error",
        "Cookie inválida",
        "El formato de la cookie no es válido.",
      );
      return;
    }

    await syncData(phpsessid);
  });

  // Verificar si ya hay una matrícula guardada
  const matriculaGuardada = localStorage.getItem("matricula");
  // Si hay matrícula guardada, se puede usar para pre-llenar datos
</script>

<style>
  kbd {
    font-family: monospace;
    font-size: 0.875rem;
  }

  code {
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
  }
</style>
