{
  "name": "sige-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:selenium": "node tests/selenium/smoke.test.mjs",
    "test:api": "newman run collections/sige-plus-api.postman_collection.json --environment collections/sige-plus-env.postman_environment.json",
    "test:security": "zaproxy -cmd -quickurl http://localhost:3000 -quickout reports/zap-report.html",
    "test:perf:k6": "k6 run tests/performance/load-test.js",
    "test:perf:artillery": "artillery run tests/performance/artillery-config.yml",
    "test:perf:jmeter": "powershell -ExecutionPolicy Bypass -File scripts/run-jmeter.ps1",
    "test:lighthouse": "lighthouse http://localhost:3000 --view",
    "lint": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "qa": "npm run lint && npm run typecheck && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "@astrojs/tailwind": "^5.1.3",
    "@astrojs/vercel": "^9.0.4",
    "@supabase/supabase-js": "^2.98.0",
    "astro": "^5.17.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui": "^2.0.0",
    "artillery": "^2.0.0",
    "eslint": "^9.0.0",
    "lighthouse": "^12.0.0",
    "newman": "^6.2.0",
    "selenium-webdriver": "^4.36.0",
    "supertest": "^7.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
